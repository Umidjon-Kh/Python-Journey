        <mxCell id="2VXDKtWfe94v90hMK1Jp-34" parent="2VXDKtWfe94v90hMK1Jp-37" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=23;fillColor=#eeeeee;strokeColor=#36393d;fontColor=default;labelBackgroundColor=none;arcSize=4;align=center;container=0;" value="The shutdown_event is checked in start() before launching threads because start() can be called even after a client-triggered stop — for example, when an exception is caught and restart_obs_event fires, which calls stop() followed by start(). Without this check, we could accidentally relaunch threads while shutdown_event is still set from the previous stop(). In stop() however, no such check is needed — even if the client calls start() while a restart-triggered stop() is in progress, the sequence is guaranteed: stop() completes first, then start() follows, so there is no risk of inconsistent state." vertex="1">
          <mxGeometry height="230" width="960" x="1840" y="880" as="geometry" />
        </mxCell>
