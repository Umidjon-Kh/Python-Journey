        <mxCell id="jMQevuQBKfGdEuFiTooe-26" parent="2VXDKtWfe94v90hMK1Jp-37" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#36393d;fontStyle=1;fontSize=26;align=center;container=0;" value="Watcher = default_env[&quot;watcher&quot;]" vertex="1">
