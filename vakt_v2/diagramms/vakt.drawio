        <mxCell id="vBWjkmojUabADJaNZe9f-7" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=18;align=center;container=0;verticalAlign=middle;fontFamily=Helvetica;fontColor=default;" value="self._build_dependency_graph(imp)" vertex="1">
          <mxGeometry height="40" width="480" x="2825" y="167.5" as="geometry" />
        </mxCell>
        <mxCell id="vBWjkmojUabADJaNZe9f-12" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;fontStyle=1;fontSize=26;align=center;container=0;" value="yields requests for client to collect of explicit client requirements for other required objects in Configure" vertex="1">
          <mxGeometry height="190" width="290" x="3095" y="365" as="geometry" />
        </mxCell>
        <mxCell id="vBWjkmojUabADJaNZe9f-14" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=23;fillColor=#eeeeee;strokeColor=#36393d;fontColor=default;labelBackgroundColor=none;arcSize=4;align=center;container=0;" value="Assembler.build_instance() is the single entry point for obtaining a fully assembled object. This method does not merely creae an instance, it performs the complete dependency resolution cycle - graph construction, client requirement gathering, validation instance creation, and target object creation. Despite its public visibility, the method is not part of the client API. It is intended for use by the infrastructure layer, primarily the Overseer. The method public because it is used not only to create runtime componenets (Watcher, Handler, etc.) but also to assemble internal infrastructure objects of the Overseer, including registries, repositories, instruction management services, and other components that may be added in the future" vertex="1">
          <mxGeometry height="369.5" width="710" x="2075" y="20.5" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-2" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=23;fillColor=#eeeeee;strokeColor=#36393d;fontColor=default;labelBackgroundColor=none;arcSize=4;align=center;container=0;" value="Assembler._build_from_map() maintains a temporary instance buffer that stores all implementation objects created during the current build cycle. This buffer serves one purpose: if an implementation declares in its requirements() that it needs another implementation of a specific port, and the buffer already contains an object of that exact type or a compatible port implementation, the Assembler asks the client whether they want to reuse the existing instance instead of creating a new one. If the client agrees — the existing instance is placed directly into the Configure object that is passed to the requesting implementation. If the client declines — a new instance is created and added to the buffer alongside the existing one." vertex="1">
          <mxGeometry height="180" width="1490" x="855" y="970" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-5" edge="1" parent="DNa5gxV0blv_Pn_uQVtT-20" source="DNa5gxV0blv_Pn_uQVtT-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" target="DNa5gxV0blv_Pn_uQVtT-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-9" edge="1" parent="DNa5gxV0blv_Pn_uQVtT-20" source="DNa5gxV0blv_Pn_uQVtT-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="DNa5gxV0blv_Pn_uQVtT-8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-3" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=23;fillColor=#f8cecc;strokeColor=#b85450;align=center;container=0;" value="define" vertex="1">
          <mxGeometry height="55" width="117.5" x="615" y="325" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-4" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;fontStyle=1;fontSize=26;align=center;container=0;" value="self._active_registries" vertex="1">
          <mxGeometry height="50" width="320" x="513.75" y="235" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-8" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088;fontStyle=1;fontSize=26;align=center;container=0;" value="self._current_map" vertex="1">
          <mxGeometry height="50" width="320" x="513.75" y="420" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-10" parent="DNa5gxV0blv_Pn_uQVtT-20" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=23;fillColor=#eeeeee;strokeColor=#36393d;fontColor=default;labelBackgroundColor=none;arcSize=4;align=center;container=0;" value="Assembler.map() returns the current environment map — a dict that the&lt;br&gt;client can inspect and edit directly before passing to build_from_map().&lt;br&gt;If the client has not changed the default environment before calling&lt;br&gt;map(), the returned map will contain the default selection.&lt;br&gt;The key convenience here: map() always returns the last built or&lt;br&gt;default map as-is — already populated, ready to edit. The client&lt;br&gt;does not start from scratch every time. This mirrors how a settings&lt;br&gt;file works in an IDE — the editor does not generate a new settings.json&lt;br&gt;on every open, it returns the existing one so the user can quickly&lt;br&gt;make targeted changes without rebuilding everything from zero." vertex="1">
          <mxGeometry height="300" width="940" x="2385" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="DNa5gxV0blv_Pn_uQVtT-19" parent="DNa5gxV0blv_Pn_uQVtT-20" style="shape=waypoint;sketch=0;size=6;pointerEvents=1;points=[];fillColor=none;resizable=0;rotatable=0;perimeter=centerPerimeter;snapToPoint=1;" value="" vertex="1">
          <mxGeometry height="20" width="20" x="605" y="940" as="geometry" />
        </mxCell>
