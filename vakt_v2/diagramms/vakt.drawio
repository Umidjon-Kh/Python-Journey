        <mxCell id="2VXDKtWfe94v90hMK1Jp-11" edge="1" parent="2VXDKtWfe94v90hMK1Jp-37" source="jMQevuQBKfGdEuFiTooe-28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="4qemiTpWNI6co6etLY_H-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="jMQevuQBKfGdEuFiTooe-28" parent="2VXDKtWfe94v90hMK1Jp-37" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=26;align=center;container=0;" value="Dispatcher(**default_env[&quot;dispatcher&quot;])" vertex="1">
          <mxGeometry height="66.25" width="540" x="270" y="450" as="geometry" />
        </mxCell>
        <mxCell id="4qemiTpWNI6co6etLY_H-1" parent="2VXDKtWfe94v90hMK1Jp-37" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=23;fillColor=#eeeeee;strokeColor=#36393d;fontColor=default;labelBackgroundColor=none;arcSize=4;align=center;container=0;" value="&lt;font face=&quot;quote-cjk-patch, Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Oxygen, Ubuntu, Cantarell, Open Sans, Helvetica Neue, sans-serif&quot;&gt;The shutdown_event is intentionally passed from the upper layer (Overseer) through Assembler rather than being created internally by Observer. This keeps Observer simple and unaware of its own lifecycle management — it doesn&#39;t need to know where dependencies come from or how they are wired. Assembler handles all injection and configuration automatically, so Observer only assigns what it receives: self._watcher, self._shutdown_event, and self._dispatcher. Additionally, Assembler pre-injects shutdown_event into both Watcher and Dispatcher instances before passing them, so Observer doesn&#39;t need to worry about propagating it either.&lt;/font&gt;" vertex="1">
          <mxGeometry height="230" width="960" y="610" as="geometry" />
        </mxCell>
