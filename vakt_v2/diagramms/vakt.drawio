        <mxCell id="2VXDKtWfe94v90hMK1Jp-29" parent="2VXDKtWfe94v90hMK1Jp-37" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=26;align=center;container=0;" value="self._watcher.stop()" vertex="1">
